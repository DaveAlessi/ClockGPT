# Environment
NODE_ENV=development

# Server
PORT=3000

# Session
SESSION_SECRET=your-secret-key-min-32-chars-change-me-in-production
SESSION_TTL_MS=86400000
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# Database
DB_PATH=./users.db

# Upload
UPLOAD_DIR=./public/images
UPLOAD_MAX_BYTES=2097152

# Security
BCRYPT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
REGISTRATION_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_MAX=10
UPLOAD_RATE_LIMIT_WINDOW_MS=900000
UPLOAD_RATE_LIMIT_MAX=30
PROFILE_PAGE_RATE_LIMIT_WINDOW_MS=900000
PROFILE_PAGE_RATE_LIMIT_MAX=120

# Logging
LOG_LEVEL=info
